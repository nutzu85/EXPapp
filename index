<script>
// ════════════════════════════════════════════════════════════════
//  CONFIG & CONSTANTS
// ════════════════════════════════════════════════════════════════
const LS = {
  apiKey:    'cheltuieli_apiKey',
  binId:     'cheltuieli_binId',
  shareCode: 'cheltuieli_shareCode',
  userName:  'cheltuieli_userName',
};
const JSONBIN_API = 'https://api.jsonbin.io/v3';

const DEFAULT_CATEGORIES = [
  {id:'c1',name:'Mâncare',emoji:'🍔'},{id:'c2',name:'Transport',emoji:'🚗'},
  {id:'c3',name:'Utilități',emoji:'💡'},{id:'c4',name:'Divertisment',emoji:'🎬'},
  {id:'c5',name:'Sănătate',emoji:'💊'},{id:'c6',name:'Îmbrăcăminte',emoji:'👕'},
  {id:'c7',name:'Educație',emoji:'📚'},{id:'c8',name:'Casă',emoji:'🏠'},
  {id:'c9',name:'Altele',emoji:'📦'},
];

const DEFAULT_ACCOUNTS = [
  { id:'acc-cash',    name:'Cash',         type:'cash',    emoji:'💵', owner:'' },
  { id:'acc-card',    name:'Card',         type:'card',    emoji:'💳', owner:'' },
  { id:'acc-tichete', name:'Tichete Masă', type:'tichete', emoji:'🎟️', owner:'' },
];

// ════════════════════════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════════════════════════
let apiKey    = localStorage.getItem(LS.apiKey)    || '';
let binId     = localStorage.getItem(LS.binId)     || '';
let shareCode = localStorage.getItem(LS.shareCode) || '';
let userName  = localStorage.getItem(LS.userName)  || '';

let appData = null;
let syncStatus = 'idle';
let lastSyncAt = null;
let lastSyncBy = '';
let saveTimer  = null;

let currentView   = 'home';
let selectedMonth = todayMonth();
let expFilter     = 'all';
let editingId     = null;
let addForm = { amount:'', description:'', categoryId:'', accountId:'', date: todayStr() };
let pendingAccType = 'cash';

// ════════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════════
function todayStr()   { return new Date().toISOString().split('T')[0]; }
function todayMonth() { const d=new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`; }
function genId()      { return Date.now().toString(36)+Math.random().toString(36).slice(2); }
function monthKey(s)  { return s ? s.slice(0,7) : ''; }

function formatMonth(ym) {
  const [y,m] = ym.split('-');
  return ['Ianuarie','Februarie','Martie','Aprilie','Mai','Iunie','Iulie','August','Septembrie','Octombrie','Noiembrie','Decembrie'][+m-1]+' '+y;
}
function shiftMonth(ym,dir) {
  const [y,m]=ym.split('-').map(Number);
  const d=new Date(y,m-1+dir,1);
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
}
function formatRon(n) { return new Intl.NumberFormat('ro-RO',{minimumFractionDigits:2,maximumFractionDigits:2}).format(n||0); }
function formatDate(s) { if(!s) return ''; return new Date(s+'T00:00:00').toLocaleDateString('ro-RO',{day:'numeric',month:'short'}); }
function formatTime(d) { if(!d) return ''; return new Date(d).toLocaleTimeString('ro-RO',{hour:'2-digit',minute:'2-digit'}); }
function getCat(id) { return appData?.categories?.find(c=>c.id===id)||{name:'Altele',emoji:'📦'}; }
function getAccount(id) {
  return appData?.accounts?.find(a=>a.id===id) || { id, name:'?', type:'cash', emoji:'💵', owner:'' };
}
function ownerName(name) { return name ? name : ''; }
function monthExps() { return (appData?.expenses||[]).filter(e=>monthKey(e.date)===selectedMonth); }
function emptyDB() {
  return {
    version: 3,
    lastModified: new Date().toISOString(),
    lastModifiedBy: userName,
    expenses: [],
    categories: [...DEFAULT_CATEGORIES],
    accounts: [...DEFAULT_ACCOUNTS],
    budgets: {},
  };
}
function migrateDB(d) {
  if (!d) return d;
  if (!d.accounts?.length) d.accounts = [...DEFAULT_ACCOUNTS];
  if (!d.categories?.length) d.categories = [...DEFAULT_CATEGORIES];
  if (!d.budgets) d.budgets = {};
  if (!d.expenses) d.expenses = [];
  d.expenses.forEach(e => { if (!e.accountId) e.accountId = 'acc-' + (e.method || 'cash'); });
  return d;
}

// ════════════════════════════════════════════════════════════════
//  JSONBIN API
// ════════════════════════════════════════════════════════════════
async function jbCreateBin(content) {
  const resp = await fetch(`${JSONBIN_API}/b`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Master-Key': apiKey,
      'X-Bin-Name':   'cheltuieli-' + (shareCode || 'default'),
      'X-Bin-Private':'false',
    },
    body: JSON.stringify(content),
  });
  if (!resp.ok) {
    const err = await resp.json().catch(()=>({}));
    throw new Error(err.message || `HTTP ${resp.status}`);
  }
  const data = await resp.json();
  return data.metadata.id;
}

async function jbReadBin(id) {
  const resp = await fetch(`${JSONBIN_API}/b/${id}/latest`, {
    headers: { 'X-Master-Key': apiKey },
  });
  if (!resp.ok) {
    const err = await resp.json().catch(()=>({}));
    throw new Error(err.message || `HTTP ${resp.status}`);
  }
  const data = await resp.json();
  return data.record;
}

async function jbUpdateBin(id, content) {
  const resp = await fetch(`${JSONBIN_API}/b/${id}`, {
    method: 'PUT',
    headers: {
      'Content-Type': 'application/json',
      'X-Master-Key': apiKey,
    },
    body: JSON.stringify(content),
  });
  if (!resp.ok) {
    const err = await resp.json().catch(()=>({}));
    throw new Error(err.message || `HTTP ${resp.status}`);
  }
}

// Search for an existing bin by name (used when joining via share code)
async function jbFindBinByCode(code) {
  // JSONBin doesn't expose bin search, so we use a separate "directory" bin
  // Actually simpler: use a deterministic ID approach via the share code itself
  // For simplicity, we ask the second user to paste the Bin ID directly
  return null;
}

// ════════════════════════════════════════════════════════════════
//  DATA LOAD/SAVE
// ════════════════════════════════════════════════════════════════
async function loadData() {
  setSyncStatus('syncing');
  try {
    const data = await jbReadBin(binId);
    appData = migrateDB(data);
    lastSyncAt = new Date();
    lastSyncBy = data.lastModifiedBy || '';
    setSyncStatus('ok');
    return data;
  } catch(err) {
    setSyncStatus('error');
    throw err;
  }
}

async function saveData() {
  if (!binId || !appData) return;
  setSyncStatus('syncing');
  try {
    appData.lastModified   = new Date().toISOString();
    appData.lastModifiedBy = userName;
    await jbUpdateBin(binId, appData);
    lastSyncAt = new Date();
    lastSyncBy = userName;
    setSyncStatus('ok');
    renderSyncBar();
  } catch(err) {
    setSyncStatus('error');
    renderSyncBar();
    showToast('Eroare sincronizare: ' + err.message, 'err');
  }
}

function scheduleSave() {
  clearTimeout(saveTimer);
  saveTimer = setTimeout(() => saveData(), 1500);
}

function setSyncStatus(s) { syncStatus = s; renderSyncBar(); }

// ════════════════════════════════════════════════════════════════
//  BOOT FLOW
// ════════════════════════════════════════════════════════════════
window.addEventListener('load', boot);

async function boot() {
  if (!apiKey)   { showSetupApiKey(); return; }
  if (!userName) { showSetupName(); return; }
  if (!binId)    { showSetupDatabase(); return; }
  await startApp();
}

function setLoader(msg) {
  document.getElementById('loader').style.display='flex';
  document.getElementById('loader-msg').textContent=msg||'Se încarcă…';
  document.getElementById('root').style.display='none';
}
function hideLoader() {
  document.getElementById('loader').style.display='none';
  document.getElementById('root').style.display='flex';
}

// ════════════════════════════════════════════════════════════════
//  SETUP: API KEY
// ════════════════════════════════════════════════════════════════
function showSetupApiKey() {
  hideLoader();
  document.getElementById('root').innerHTML = `
    <div class="screen">
      <div class="setup-wrap">
        <div class="setup-logo">💳</div>
        <div class="setup-title">Cheltuieli RON</div>
        <div class="setup-sub">Tracker de cheltuieli cu sincronizare cloud pentru 2 utilizatori. Foarte simplu — fără Google.</div>

        <div class="setup-card">
          <h3>📋 Pasul 1 — Obține o cheie gratuită JSONBin</h3>
          <div class="step-row"><div class="step-num">1</div><div class="step-text">Mergi la <a href="https://jsonbin.io" target="_blank">jsonbin.io</a> și apasă <strong>Sign Up Free</strong></div></div>
          <div class="step-row"><div class="step-num">2</div><div class="step-text">Înregistrează-te cu un email (sau cu Google). Confirmă emailul dacă e cazul.</div></div>
          <div class="step-row"><div class="step-num">3</div><div class="step-text">După login, în meniul din stânga apasă <strong>API Keys</strong></div></div>
          <div class="step-row"><div class="step-num">4</div><div class="step-text">Apasă <strong>Create Access Key</strong> (sau folosește <strong>X-MASTER-KEY</strong> care există deja)</div></div>
          <div class="step-row"><div class="step-num">5</div><div class="step-text">Copiază cheia (un șir lung de caractere)</div></div>
        </div>

        <div class="setup-card">
          <h3>🔑 Pasul 2 — Lipește cheia aici</h3>
          <label class="form-label">JSONBin API Key</label>
          <input type="text" class="form-input mono" id="inp-apikey" placeholder="$2a$10$xxxxxxxxxxxx..." style="margin-bottom:12px">
          <button class="btn-primary" onclick="saveApiKey()">Continuă →</button>
        </div>

        <div style="font-size:11px;color:var(--text3);text-align:center;line-height:1.6;max-width:340px;margin-top:8px">
          💡 <strong>De ce JSONBin?</strong> Este un serviciu gratuit unde aplicația salvează datele tale ca un fișier JSON. Cheia API e ca o parolă — nu o partaja public. Ambii utilizatori folosesc <strong>aceeași cheie</strong>.
        </div>
      </div>
    </div>`;
}

function saveApiKey() {
  const val = document.getElementById('inp-apikey').value.trim();
  if (!val || val.length < 20) { showToast('Cheie invalidă!','err'); return; }
  apiKey = val;
  localStorage.setItem(LS.apiKey, apiKey);
  showSetupName();
}

// ════════════════════════════════════════════════════════════════
//  SETUP: USERNAME
// ════════════════════════════════════════════════════════════════
function showSetupName() {
  hideLoader();
  document.getElementById('root').innerHTML = `
    <div class="screen">
      <div class="setup-wrap">
        <div class="setup-logo">👤</div>
        <div class="setup-title">Numele tău</div>
        <div class="setup-sub">Cum să apari pe cheltuielile pe care le adaugi (ca celălalt utilizator să știe cine a făcut ce).</div>

        <div class="setup-card">
          <label class="form-label">Numele tău</label>
          <input type="text" class="form-input" id="inp-name" placeholder="Ex: Andrei" style="margin-bottom:12px" maxlength="20">
          <button class="btn-primary" onclick="saveName()">Continuă →</button>
        </div>

        <button class="link-btn" onclick="showSetupApiKey()" style="margin-top:8px">← Schimbă cheia API</button>
      </div>
    </div>`;
  setTimeout(()=>document.getElementById('inp-name').focus(), 100);
  document.getElementById('inp-name').addEventListener('keydown', e => { if(e.key==='Enter') saveName(); });
}

function saveName() {
  const val = document.getElementById('inp-name').value.trim();
  if (!val) { showToast('Adaugă un nume!','err'); return; }
  userName = val;
  localStorage.setItem(LS.userName, userName);
  showSetupDatabase();
}

// ════════════════════════════════════════════════════════════════
//  SETUP: DATABASE
// ════════════════════════════════════════════════════════════════
let setupTab = 'create';
function showSetupDatabase() {
  hideLoader();
  document.getElementById('root').innerHTML = `
    <div class="screen">
      <div class="setup-wrap">
        <div class="setup-logo">🗄️</div>
        <div class="setup-title">Baza de date</div>
        <div class="setup-sub">Bună, <strong>${userName}</strong>! Acum alege:</div>

        <div class="setup-card" style="width:100%">
          <div class="opt-tabs">
            <button class="opt-tab ${setupTab==='create'?'active':''}" onclick="setSetupTab('create')">✨ Începe nou</button>
            <button class="opt-tab ${setupTab==='join'?'active':''}" onclick="setSetupTab('join')">🔗 Conectare</button>
          </div>

          <div id="setup-tab-content"></div>
        </div>

        <button class="link-btn" onclick="showSetupName()" style="margin-top:8px">← Schimbă numele</button>
        <button class="link-btn" onclick="resetAll()" style="margin-top:8px;color:var(--danger)">Resetează tot</button>
      </div>
    </div>`;
  renderSetupTab();
}

function setSetupTab(t) { setupTab = t; renderSetupTab(); document.querySelectorAll('.opt-tab').forEach((b,i)=>{ b.classList.toggle('active', (t==='create'&&i===0)||(t==='join'&&i===1)); }); }

function renderSetupTab() {
  const c = document.getElementById('setup-tab-content');
  if (setupTab === 'create') {
    c.innerHTML = `
      <p style="font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:14px">
        Creează o bază de date nouă. Aplicația îți va da un <strong>cod de partajare</strong> pe care îl trimiți celuilalt utilizator pentru a se conecta.
      </p>
      <button class="btn-primary" onclick="createNewDB()">✨ Creează bază de date nouă</button>`;
  } else {
    c.innerHTML = `
      <p style="font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:14px">
        Introdu codul de partajare primit de la celălalt utilizator.
      </p>
      <label class="form-label">Cod de partajare</label>
      <input type="text" class="form-input big" id="inp-code" placeholder="abc123def..." style="margin-bottom:12px" autocapitalize="off" autocorrect="off">
      <button class="btn-primary" onclick="joinExistingDB()">🔗 Conectează-te</button>`;
  }
}

async function createNewDB() {
  setLoader('Se creează baza de date…');
  try {
    const db = emptyDB();
    const id = await jbCreateBin(db);
    binId = id;
    shareCode = id;
    localStorage.setItem(LS.binId, binId);
    localStorage.setItem(LS.shareCode, shareCode);
    appData = db;
    await startApp();
    setTimeout(showShareCodeModal, 600);
  } catch(err) {
    hideLoader();
    showSetupDatabase();
    showToast('Eroare: ' + err.message, 'err');
  }
}

async function joinExistingDB() {
  const code = document.getElementById('inp-code').value.trim();
  if (!code) { showToast('Introdu codul!','err'); return; }
  setLoader('Se conectează…');
  try {
    binId = code;
    shareCode = code;
    await loadData();
    localStorage.setItem(LS.binId, binId);
    localStorage.setItem(LS.shareCode, shareCode);
    await startApp();
  } catch(err) {
    binId = '';
    shareCode = '';
    hideLoader();
    showSetupDatabase();
    showToast('Cod invalid sau cheie API greșită','err');
  }
}

function showShareCodeModal() {
  document.getElementById('modal-content').innerHTML = `
    <div class="modal-title">📤 Cod de partajare</div>
    <p style="font-size:13px;color:var(--text2);margin-bottom:14px;line-height:1.6">
      Trimite acest cod celuilalt utilizator. El va folosi aceeași cheie API JSONBin și acest cod pentru a se conecta la aceleași date.
    </p>
    <div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:14px;text-align:center;font-family:monospace;font-size:14px;word-break:break-all;color:var(--accent)" id="code-display">${shareCode}</div>
    <button class="btn-primary" onclick="copyShareCode()" style="margin-bottom:8px">📋 Copiază codul</button>
    <button class="btn-secondary" onclick="closeModal()">Am înțeles</button>`;
  openModal();
}

function copyShareCode() {
  navigator.clipboard.writeText(shareCode).then(()=>{
    showToast('Cod copiat ✓','ok');
  }).catch(()=>{
    document.getElementById('code-display').setAttribute('contenteditable','true');
    document.execCommand('selectAll');
  });
}

function resetAll() {
  if (!confirm('Sigur vrei să resetezi totul (cheia API, numele, codul)?')) return;
  localStorage.clear();
  apiKey = ''; binId = ''; shareCode = ''; userName = ''; appData = null;
  showSetupApiKey();
}

// ════════════════════════════════════════════════════════════════
//  START APP
// ════════════════════════════════════════════════════════════════
async function startApp() {
  setLoader('Se încarcă datele…');
  try {
    if (!appData) await loadData();
    renderApp();
    hideLoader();
    navigate('home');
  } catch(err) {
    hideLoader();
    document.getElementById('root').innerHTML = `
      <div class="screen"><div class="setup-wrap">
        <div style="font-size:48px">⚠️</div>
        <div class="setup-title">Eroare</div>
        <div class="setup-sub">${err.message}</div>
