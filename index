function navigate(view) {
  currentView = view;
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('nav-'+view)?.classList.add('active');
  document.getElementById('view-content').scrollTop = 0;
  renderView();
}

function renderView() {
  const c = document.getElementById('view-content');
  if (!c) return;
  c.innerHTML = '';
  c.classList.add('fade-in');
  setTimeout(()=>c.classList.remove('fade-in'),300);
  const map = { home:renderHome, expenses:renderExpenses, add:()=>renderAdd(null), budget:renderBudget, settings:renderSettings, help:renderHelp };
  map[currentView]?.();
}

function handleScroll(e) {
  if (e.target.id !== 'view-content') return;
  const h = e.target.querySelector('.page-header');
  if (h) h.classList.toggle('scrolled', e.target.scrollTop > 6);
}

