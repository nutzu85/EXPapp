<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#0d1117">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>Cheltuieli RON</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:#0d1117; --surface:#161b22; --surface2:#1e2530; --surface3:#252d3a;
      --border:#2a3441; --accent:#00d68f; --accent-dim:rgba(0,214,143,0.12);
      --text:#e8edf3; --text2:#8b96a5; --text3:#5a6474;
      --danger:#ff5c5c; --danger-dim:rgba(255,92,92,0.12);
      --card-color:#4f8ef7; --card-dim:rgba(79,142,247,0.12);
      --tichete:#f5a623; --tichete-dim:rgba(245,166,35,0.14);
      --radius:16px; --radius-sm:10px;
      --nav-h:72px; --safe-bottom:env(safe-area-inset-bottom,0px);
    }
    *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
    html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'Lexend',sans-serif;font-size:15px;line-height:1.5}
    #root{height:100%;display:flex;flex-direction:column;max-width:480px;margin:0 auto;position:relative}

    .screen{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .screen::-webkit-scrollbar{display:none}
    .screen.has-nav{padding-bottom:calc(var(--nav-h) + var(--safe-bottom) + 16px)}

    #loader{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;z-index:9999}
    .spinner{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .75s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    #loader p{font-size:13px;color:var(--text2)}

    .setup-wrap{min-height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px}
    .setup-logo{font-size:52px;margin-bottom:8px}
    .setup-title{font-family:'Fraunces',serif;font-size:28px;font-weight:700;text-align:center;margin-bottom:6px}
    .setup-sub{font-size:13px;color:var(--text2);text-align:center;margin-bottom:24px;line-height:1.6;max-width:340px}
    .setup-card{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px;margin-bottom:14px}
    .setup-card h3{font-size:13px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:14px}
    .step-row{display:flex;gap:12px;align-items:flex-start;padding:11px 0;border-top:1px solid var(--border)}
    .step-row:first-of-type{border-top:none;padding-top:4px}
    .step-num{width:24px;height:24px;border-radius:50%;background:var(--accent-dim);border:1px solid rgba(0,214,143,.3);color:var(--accent);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
    .step-text{font-size:13px;color:var(--text2);line-height:1.65;flex:1}
    .step-text strong{color:var(--text);font-weight:600}
    .step-text code{background:var(--surface2);padding:2px 6px;border-radius:4px;font-size:12px;color:var(--accent);font-family:monospace}
    .step-text a{color:var(--accent);text-decoration:underline}
    .form-label{display:block;font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:8px;margin-top:8px}
    .form-input{width:100%;background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:13px 14px;color:var(--text);font-family:'Lexend',sans-serif;font-size:14px;outline:none;transition:border-color .2s;-webkit-appearance:none}
    .form-input:focus{border-color:var(--accent)}
    .form-input.mono{font-family:monospace;font-size:12px;letter-spacing:.5px}
    .form-input.big{font-family:'Fraunces',serif;font-size:22px;font-weight:600;text-align:center;letter-spacing:1px}
    .btn-primary{width:100%;padding:15px;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#0d1117;font-family:'Lexend',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:6px}
    .btn-primary:active{transform:scale(.98);opacity:.9}
    .btn-primary:disabled{opacity:.4;cursor:not-allowed;transform:none}
    .btn-secondary{width:100%;padding:13px;background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'Lexend',sans-serif;font-size:14px;font-weight:500;cursor:pointer;transition:all .2s}
    .btn-secondary:active{background:var(--surface3)}
    .btn-danger{background:var(--danger-dim);border-color:rgba(255,92,92,.3);color:var(--danger)}
    .link-btn{background:none;border:none;color:var(--accent);font-family:'Lexend',sans-serif;font-size:13px;cursor:pointer;text-decoration:underline;padding:0}
    .opt-tabs{display:flex;gap:6px;margin-bottom:14px;background:var(--surface2);padding:4px;border-radius:var(--radius-sm)}
    .opt-tab{flex:1;padding:10px;text-align:center;border-radius:6px;font-size:13px;font-weight:500;color:var(--text2);cursor:pointer;transition:all .15s;border:none;background:none;font-family:'Lexend',sans-serif}
    .opt-tab.active{background:var(--accent);color:#0d1117;font-weight:700}

    /* SYNC BAR */
    #sync-bar{padding:8px 20px;display:flex;align-items:center;justify-content:space-between;gap:8px;border-bottom:1px solid var(--border);background:var(--bg);min-height:36px}
    .sync-status{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2)}
    .sync-dot{width:6px;height:6px;border-radius:50%;background:var(--text3);flex-shrink:0}
    .sync-dot.ok{background:var(--accent);animation:pulse 2.5s infinite}
    .sync-dot.syncing{background:var(--card-color);animation:spin .8s linear infinite;border-top-color:transparent}
    .sync-dot.error{background:var(--danger)}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
    .sync-user{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:6px}
    .avatar{width:20px;height:20px;border-radius:50%;background:var(--accent-dim);border:1px solid rgba(0,214,143,.3);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--accent);text-transform:uppercase}
    .sync-btn{padding:4px 10px;border-radius:99px;background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-family:'Lexend',sans-serif;font-size:11px;cursor:pointer;transition:all .15s;white-space:nowrap}
    .sync-btn:active{background:var(--surface3);transform:scale(.95)}

    /* BOTTOM NAV */
    .bottom-nav{position:absolute;bottom:0;left:0;right:0;height:calc(var(--nav-h) + var(--safe-bottom));background:var(--surface);border-top:1px solid var(--border);display:flex;align-items:flex-start;padding-top:8px;z-index:100}
    .nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 4px;cursor:pointer;border:none;background:none;color:var(--text3);font-family:'Lexend',sans-serif;transition:color .2s}
    .nav-item.active{color:var(--accent)}
    .nav-item svg{width:22px;height:22px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
    .nav-item span{font-size:10px;font-weight:500}
    .nav-add{width:52px;height:52px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-top:-20px;box-shadow:0 4px 20px rgba(0,214,143,.4);transition:transform .2s}
    .nav-add:active{transform:scale(.92)}
    .nav-add svg{stroke:#0d1117;width:24px;height:24px;stroke-width:2.5}

    .page-header{padding:16px 20px 10px;position:sticky;top:0;background:var(--bg);z-index:10;border-bottom:1px solid transparent;transition:border-color .2s}
    .page-header.scrolled{border-color:var(--border)}
    .page-title{font-family:'Fraunces',serif;font-size:24px;font-weight:700;letter-spacing:-.5px}
    .page-subtitle{font-size:12px;color:var(--text2);margin-top:2px}

    .month-picker{display:flex;align-items:center;gap:12px;padding:0 20px 14px}
    .month-btn{width:34px;height:34px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
    .month-btn:active{transform:scale(.9)}
    .month-btn svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
    .month-label{flex:1;text-align:center;font-size:15px;font-weight:600}

    .big-summary{margin:0 20px 12px;background:linear-gradient(135deg,#1a2535,#0f1a2a);border:1px solid var(--border);border-radius:var(--radius);padding:20px;position:relative;overflow:hidden}
    .big-summary::after{content:'lei';position:absolute;right:16px;bottom:8px;font-family:'Fraunces',serif;font-size:64px;font-weight:700;color:rgba(255,255,255,.03);line-height:1}
    .big-label{font-size:11px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--text2)}
    .big-value{font-family:'Fraunces',serif;font-size:40px;font-weight:700;color:var(--text);letter-spacing:-1px;line-height:1.1;margin-top:4px}
    .big-value span{font-size:18px;color:var(--text2);font-weight:400}
    .progress-bar{height:6px;background:var(--surface3);border-radius:99px;overflow:hidden;margin-top:12px}
    .progress-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--accent),#00a8d6);transition:width .6s cubic-bezier(.4,0,.2,1)}
    .progress-fill.over{background:linear-gradient(90deg,#f5a623,var(--danger))}
    .progress-meta{display:flex;justify-content:space-between;margin-top:5px;font-size:11px;color:var(--text2)}

    .acc-cards-row{display:flex;gap:10px;overflow-x:auto;padding:0 20px 12px;-webkit-overflow-scrolling:touch;scroll-snap-type:x mandatory}
    .acc-cards-row::-webkit-scrollbar{display:none}
    .acc-card{flex-shrink:0;width:148px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px;position:relative;overflow:hidden;scroll-snap-align:start}
    .acc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
    .acc-card.t-cash::before{background:var(--accent)}
    .acc-card.t-card::before{background:var(--card-color)}
    .acc-card.t-tichete::before{background:var(--tichete)}
    .ac-hdr{display:flex;align-items:center;gap:6px;margin-bottom:8px}
    .ac-emoji{font-size:18px}
    .ac-name{font-size:11px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
    .ac-owner-tag{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ac-spent{font-family:'Fraunces',serif;font-size:18px;font-weight:700;color:var(--text);letter-spacing:-.3px;line-height:1.1}
    .ac-spent .cur{font-size:11px;font-weight:400;color:var(--text2);margin-left:2px}
    .ac-rem{font-size:10px;color:var(--text2);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ac-rem.over{color:var(--danger)}

    .section{padding:0 20px 16px}
    .section-title{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--text2);margin-bottom:10px}

    .expense-list{display:flex;flex-direction:column;gap:8px}
    .expense-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:13px 13px 13px 15px;display:flex;align-items:center;gap:10px;position:relative;overflow:hidden}
    .expense-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
    .expense-item.cash-item::before{background:var(--accent)}
    .expense-item.card-item::before{background:var(--card-color)}
    .expense-item.tichete-item::before{background:var(--tichete)}
    .exp-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
    .exp-info{flex:1;min-width:0}
    .exp-desc{font-weight:500;color:var(--text);font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .exp-meta{font-size:11px;color:var(--text2);margin-top:2px}
    .exp-badge{display:inline-flex;align-items:center;padding:1px 6px;border-radius:99px;font-size:9px;font-weight:600;margin-right:4px}
    .badge-cash{background:var(--accent-dim);color:var(--accent)}
    .badge-card{background:var(--card-dim);color:var(--card-color)}
    .badge-tichete{background:var(--tichete-dim);color:var(--tichete)}
    .added-by{display:inline-flex;align-items:center;gap:4px;padding:1px 7px 1px 2px;border-radius:99px;background:var(--surface2);border:1px solid var(--border);font-size:9px;font-weight:600;color:var(--text2);margin-left:4px}
    .added-by .ab-avatar{width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#fff;text-transform:uppercase;flex-shrink:0}
    .ab-me{background:var(--accent)}
    .ab-other{background:var(--card-color)}
    .exp-amount{font-family:'Fraunces',serif;font-size:16px;font-weight:600;color:var(--danger);white-space:nowrap}
    .exp-actions{display:flex;gap:5px}
    .icon-btn{width:30px;height:30px;border-radius:8px;border:none;background:var(--surface2);color:var(--text2);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
    .icon-btn:active{transform:scale(.88)}
    .icon-btn.del:active{background:var(--danger-dim);color:var(--danger)}
    .icon-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
    .empty-state{text-align:center;padding:36px 20px;color:var(--text2)}
    .empty-state .emoji{font-size:44px;margin-bottom:10px}
    .empty-state p{font-size:13px}

    .form-view{padding:0 20px}
    .form-group{margin-bottom:16px}
    .form-label-sm{display:block;font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2);margin-bottom:7px}
    .form-inp{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:13px 15px;color:var(--text);font-family:'Lexend',sans-serif;font-size:14px;outline:none;transition:border-color .2s;-webkit-appearance:none;appearance:none}
    .form-inp:focus{border-color:var(--accent)}
    .amount-inp{font-family:'Fraunces',serif;font-size:30px;font-weight:700;text-align:center;letter-spacing:-.5px}
    .amount-wrap{position:relative}
    .amount-cur{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:13px;color:var(--text2);pointer-events:none}

    .acc-picker{display:flex;gap:7px;overflow-x:auto;padding:3px 0 5px}
    .acc-picker::-webkit-scrollbar{display:none}
    .acc-pill{flex-shrink:0;min-width:88px;padding:11px 12px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);color:var(--text2);font-family:'Lexend',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:3px;line-height:1.2;text-align:center}
    .acc-pill .ap-emoji{font-size:18px}
    .acc-pill .ap-name{white-space:nowrap;font-size:12px}
    .acc-pill .ap-owner{font-size:9px;color:var(--text3);font-weight:600;margin-top:1px;letter-spacing:.2px}
    .acc-pill.sel-cash{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}
    .acc-pill.sel-cash .ap-owner{color:var(--accent)}
    .acc-pill.sel-card{background:var(--card-dim);border-color:var(--card-color);color:var(--card-color)}
    .acc-pill.sel-card .ap-owner{color:var(--card-color)}
    .acc-pill.sel-tichete{background:var(--tichete-dim);border-color:var(--tichete);color:var(--tichete)}
    .acc-pill.sel-tichete .ap-owner{color:var(--tichete)}

    .toggle-group{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px}
    .tog-btn{padding:11px 4px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);color:var(--text2);font-family:'Lexend',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:3px;line-height:1.2}
    .tog-btn .tog-emoji{font-size:18px}
    .tog-btn.cash-on{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}
    .tog-btn.card-on{background:var(--card-dim);border-color:var(--card-color);color:var(--card-color)}
    .tog-btn.tichete-on{background:var(--tichete-dim);border-color:var(--tichete);color:var(--tichete)}

    .cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px}
    .cat-btn{padding:9px 5px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);color:var(--text2);font-family:'Lexend',sans-serif;font-size:11px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:3px}
    .cat-btn .ce{font-size:19px}
    .cat-btn.sel{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}

    .budget-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px}
    .bud-hdr{display:flex;align-items:center;gap:10px;margin-bottom:14px}
    .bud-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:19px}
    .bud-icon.cash-icon{background:var(--accent-dim)}
    .bud-icon.card-icon{background:var(--card-dim)}
    .bud-icon.tichete-icon{background:var(--tichete-dim)}
    .bud-title{font-size:15px;font-weight:600}
    .bud-desc{font-size:11px;color:var(--text2)}
    .bud-row{display:flex;gap:8px;align-items:center}
    .bud-inp-wrap{flex:1;position:relative}
    .bud-inp-wrap input{width:100%;background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:11px 44px 11px 12px;color:var(--text);font-family:'Fraunces',serif;font-size:19px;font-weight:700;outline:none;transition:border-color .2s;-webkit-appearance:none}
    .bud-inp-wrap input:focus{border-color:var(--accent)}
    .bud-inp-wrap .sfx{position:absolute;right:10px;top:50%;transform:translateY(-50%);font-size:12px;color:var(--text2);pointer-events:none}
    .save-btn{padding:11px 16px;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#0d1117;font-family:'Lexend',sans-serif;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;transition:all .2s}
    .save-btn:active{transform:scale(.95)}
    .stat-row{display:flex;justify-content:space-between;padding:9px 0;border-top:1px solid var(--border)}
    .stat-label{font-size:12px;color:var(--text2)}
    .stat-value{font-size:12px;font-weight:600}
    .green{color:var(--accent)}
    .red{color:var(--danger)}

    .acc-item{display:flex;align-items:center;gap:10px;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:7px;position:relative;overflow:hidden}
    .acc-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
    .acc-item.t-cash::before{background:var(--accent)}
    .acc-item.t-card::before{background:var(--card-color)}
    .acc-item.t-tichete::before{background:var(--tichete)}
    .acc-item-emoji{font-size:20px;width:30px;text-align:center}
    .acc-item-info{flex:1;min-width:0}
    .acc-item-name{font-weight:500;font-size:13px}
    .acc-item-meta{font-size:10px;color:var(--text2);margin-top:1px}

    .cat-item{display:flex;align-items:center;gap:10px;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:7px}
    .cat-item-emoji{font-size:21px;width:32px;text-align:center}
    .cat-item-name{flex:1;font-weight:500;font-size:13px}
    .cat-add-form{display:flex;gap:7px;margin-bottom:14px}
    .emoji-inp,.name-inp{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:11px;color:var(--text);font-family:'Lexend',sans-serif;font-size:13px;outline:none;transition:border-color .2s}
    .emoji-inp{width:56px;text-align:center;font-size:19px}
    .emoji-inp:focus,.name-inp:focus{border-color:var(--accent)}
    .name-inp{flex:1}
    .cat-add-btn{padding:11px 14px;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#0d1117;font-family:'Lexend',sans-serif;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;transition:all .2s}
    .cat-add-btn:active{transform:scale(.95)}

