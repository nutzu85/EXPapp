    </div>
    <div class="big-summary">
      <div class="big-label">Total Cheltuit</div>
      <div class="big-value">${formatRon(totalSpent)} <span>RON</span></div>
      ${totalBudget>0 ? `
      <div class="progress-bar"><div class="progress-fill ${pct>90?'over':''}" style="width:${pct}%"></div></div>
      <div class="progress-meta">
        <span>${Math.round(pct)}% din buget</span>
        <span style="color:${rem<0?'var(--danger)':'var(--accent)'}">${rem<0?'-':''}${formatRon(Math.abs(rem))} lei ${rem<0?'depășit':'rămas'}</span>
      </div>` : `<div style="font-size:11px;color:var(--text3);margin-top:8px">Setează buget în secțiunea Buget →</div>`}
    </div>`;

  const accounts = appData.accounts || [];
  if (accounts.length) {
    html += `<div class="section-title" style="padding:0 20px 8px;margin:0">📊 Conturi (${accounts.length})</div>`;
    html += `<div class="acc-cards-row">`;
    accounts.forEach(acc => {
      const spent = spentFor(acc.id);
      const bud   = monthBudget[acc.id] || 0;
      const remA  = bud - spent;
      html += `
        <div class="acc-card t-${acc.type}">
          <div class="ac-hdr"><span class="ac-emoji">${acc.emoji}</span><span class="ac-name">${acc.name}</span></div>
          ${acc.owner ? `<div class="ac-owner-tag">👤 ${acc.owner}</div>` : `<div class="ac-owner-tag" style="color:var(--text3)">comun</div>`}
          <div style="height:6px"></div>
          <div class="ac-spent">${formatRon(spent)}<span class="cur">lei</span></div>
          <div class="ac-rem ${remA<0?'over':''}">${bud>0?(remA>=0?`${formatRon(remA)} rămas`:`${formatRon(Math.abs(remA))} depășit`):'— fără buget'}</div>
        </div>`;
    });
