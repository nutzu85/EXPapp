      </div>`;
  }
  html += `</div>`;
  c.innerHTML = html;
}

function saveBudget(accountId) {
  const val = parseFloat(document.getElementById(`bud-${accountId}`).value)||0;
  if (!appData.budgets) appData.budgets = {};
  if (!appData.budgets[selectedMonth]) appData.budgets[selectedMonth] = {};
  appData.budgets[selectedMonth][accountId] = val;
  scheduleSave();
  showToast(`Buget "${getAccount(accountId).name}" salvat ✓`,'ok');
  renderBudget();
}

