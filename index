  }

  const catBtns = appData.categories.map(cat=>`
    <div class="cat-btn ${addForm.categoryId===cat.id?'sel':''}" onclick="selectCat('${cat.id}',this)"><div class="ce">${cat.emoji}</div><div>${cat.name}</div></div>`).join('');

