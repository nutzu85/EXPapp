function renderExpenses() {
  const c = document.getElementById('view-content');
  const exps = monthExps();
  let filtered = exps;
  if (expFilter !== 'all') filtered = exps.filter(e=>e.accountId===expFilter);
  const sorted = [...filtered].sort((a,b)=>b.date.localeCompare(a.date));

  let html = `
    <div class="page-header"><div class="page-title">Cheltuieli</div><div class="page-subtitle">${formatMonth(selectedMonth)}</div></div>
    <div class="month-picker">
      <button class="month-btn" onclick="changeMonth(-1)"><svg viewBox="0 0 24 24"><polyline points="15,18 9,12 15,6"/></svg></button>
      <div class="month-label">${formatMonth(selectedMonth)}</div>
      <button class="month-btn" onclick="changeMonth(1)"><svg viewBox="0 0 24 24"><polyline points="9,18 15,12 9,6"/></svg></button>
    </div>
    <div class="filter-bar">
      <div class="chip ${expFilter==='all'?'active':''}" onclick="setFilter('all')">Toate (${exps.length})</div>`;
  (appData.accounts||[]).forEach(acc => {
    const n = exps.filter(e=>e.accountId===acc.id).length;
    const ol = acc.owner ? ` · ${acc.owner}` : '';
    html += `<div class="chip ${expFilter===acc.id?'active':''}" onclick="setFilter('${acc.id}')">${acc.emoji} ${acc.name}${ol} (${n})</div>`;
  });
  html += `</div><div class="section">`;

  if (!sorted.length) {
    html += `<div class="empty-state"><div class="emoji">📭</div><p>Nicio cheltuială pentru filtrul selectat.</p></div>`;
  } else {
    const groups = {};
    sorted.forEach(e=>{ if(!groups[e.date]) groups[e.date]=[]; groups[e.date].push(e); });
    html += `<div class="expense-list">`;
    Object.entries(groups).forEach(([date,items])=>{
      const dt = items.reduce((s,e)=>s+e.amount,0);
      html += `<div style="display:flex;justify-content:space-between;align-items:center;padding:7px 0 3px;border-top:1px solid var(--border);margin-top:4px">
        <span style="font-size:11px;font-weight:600;color:var(--text2)">${formatDate(date)}</span>
        <span style="font-size:11px;color:var(--text3)">${formatRon(dt)} lei</span>
      </div>${items.map(expHtml).join('')}`;
    });
    html += `</div>`;
    const total = filtered.reduce((s,e)=>s+e.amount,0);
    html += `<div style="margin-top:14px;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);display:flex;justify-content:space-between;align-items:center">
      <span style="font-weight:600;color:var(--text2)">Total</span>
      <span style="font-family:'Fraunces',serif;font-size:19px;font-weight:700;color:var(--danger)">${formatRon(total)} <span style="font-size:12px;color:var(--text2)">lei</span></span>
    </div>`;
  }
  html += `</div>`;
  c.innerHTML = html;
}
function setFilter(f) { expFilter=f; renderExpenses(); }

