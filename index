      <div class="page-title">${isEdit?'Editează':'Cheltuială nouă'}</div>
      <div class="page-subtitle">${isEdit?'Modifică detaliile':'Completează detaliile'}</div>
    </div>
    <div class="form-view">
      <div class="form-group">
        <label class="form-label-sm">Suma (RON)</label>
        <div class="amount-wrap">
          <input type="number" class="form-inp amount-inp" id="inp-amount" placeholder="0.00" inputmode="decimal" step="0.01" min="0" value="${addForm.amount}" oninput="addForm.amount=this.value">
          <span class="amount-cur">lei</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label-sm">Descriere</label>
        <input type="text" class="form-inp" placeholder="Ex: Cumpărături Mega" value="${addForm.description}" oninput="addForm.description=this.value">
      </div>
      <div class="form-group">
        <label class="form-label-sm">Cont (metoda de plată)</label>
        <div class="acc-picker">${accPills || '<span style="font-size:12px;color:var(--text3);padding:8px">Adaugă conturi în Setări</span>'}</div>
      </div>
      <div class="form-group">
        <label class="form-label-sm">Categorie</label>
        <div class="cat-grid">${catBtns}</div>
      </div>
      <div class="form-group">
        <label class="form-label-sm">Data</label>
        <input type="date" class="form-inp" value="${addForm.date}" onchange="addForm.date=this.value">
      </div>
      <button class="btn-primary" onclick="saveExpense()">${isEdit?'✓ Salvează':'+ Adaugă Cheltuială'}</button>
      ${isEdit?`<div style="height:10px"></div><button class="btn-secondary" onclick="navigate('expenses')">Anulează</button>`:''}
      <div style="height:20px"></div>
    </div>`;
  setTimeout(()=>document.getElementById('inp-amount')?.focus(),150);
}

function selectCat(id,el) { addForm.categoryId=id; document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('sel')); el.classList.add('sel'); }
function selectAccount(id,type,el) {
  addForm.accountId = id;
  document.querySelectorAll('.acc-pill').forEach(b=>b.classList.remove('sel-cash','sel-card','sel-tichete'));
  el.classList.add('sel-'+type);
}

function saveExpense() {
  const amount = parseFloat(addForm.amount);
  if (!amount||amount<=0) { showToast('Sumă invalidă!','err'); return; }
  if (!addForm.description.trim()) { showToast('Adaugă o descriere!','err'); return; }
  if (!addForm.date) { showToast('Selectează o dată!','err'); return; }
  if (!addForm.accountId) { showToast('Alege un cont!','err'); return; }
  if (!addForm.categoryId) addForm.categoryId = appData.categories[0]?.id||'c9';

  const acc = getAccount(addForm.accountId);
  const rec = {
    id: editingId||genId(),
    amount,
    description: addForm.description.trim(),
    categoryId:  addForm.categoryId,
    accountId:   addForm.accountId,
    method:      acc.type,
    date:        addForm.date,
    addedBy:     userName,
    updatedAt:   new Date().toISOString(),
  };

  if (editingId) {
    const idx = appData.expenses.findIndex(e=>e.id===editingId);
    if (idx!==-1) appData.expenses[idx] = {...appData.expenses[idx], ...rec};
    showToast('Actualizat ✓','ok');
  } else {
    rec.createdAt = new Date().toISOString();
    appData.expenses.push(rec);
    showToast('Adăugat ✓','ok');
  }
  selectedMonth = monthKey(addForm.date);
  scheduleSave();
  navigate('home');
}

