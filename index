function renderHelp() {
  const c = document.getElementById('view-content');
  c.innerHTML = `
    <div class="page-header">
      <button class="back-btn" onclick="navigate('home')"><svg viewBox="0 0 24 24"><polyline points="15,18 9,12 15,6"/></svg>Înapoi</button>
      <div class="page-title">Cum funcționează</div>
      <div class="page-subtitle">Ghid de utilizare</div>
    </div>
    <div class="help-view">

      <div class="help-section">
        <h3>🚀 Început rapid</h3>
        <p>Aplicația te ajută să urmărești cheltuielile lunare în <strong>RON</strong>. Datele sunt stocate în cloud (JSONBin) și se sincronizează între 2 utilizatori care folosesc același <strong>cod de partajare</strong>.</p>
        <ul>
          <li>Apasă <strong>+</strong> verde din mijlocul barei pentru a adăuga o cheltuială</li>
          <li>Vezi rezumatul lunar pe ecranul <strong>Acasă</strong></li>
          <li>Setează bugete în <strong>Buget</strong></li>
          <li>Configurează conturi și categorii în <strong>Setări</strong></li>
        </ul>
      </div>

      <div class="help-section">
        <h3>👥 Doi utilizatori — cum să partajezi</h3>
        <p><strong>Primul utilizator (creatorul):</strong></p>
        <ul>
          <li>Își face cont gratuit pe <a href="https://jsonbin.io" target="_blank">jsonbin.io</a></li>
          <li>Își ia cheia API → o pune în aplicație</li>
          <li>Își alege un nume → creează baza de date nouă</li>
          <li>Mergi la <em>Setări → Arată codul</em> și trimite-i celuilalt: <strong>cheia API</strong> + <strong>codul de partajare</strong></li>
        </ul>
        <p><strong>Al doilea utilizator:</strong></p>
        <ul>
          <li>Deschide aplicația, pune <strong>aceeași cheie API</strong> primită</li>
          <li>Își alege un nume diferit (ex: Maria)</li>
          <li>Pe ecranul "Baza de date" alege <strong>🔗 Conectare</strong></li>
          <li>Lipește codul de partajare → Conectează-te</li>
        </ul>
        <div class="help-tip"><strong>💡 Tip:</strong> Pe fiecare cheltuială vezi cine a adăugat-o (avatar verde = tu, albastru = celălalt).</div>
      </div>

      <div class="help-section">
        <h3>🏦 Conturi (metodele de plată)</h3>
        <p>Conturile reprezintă <strong>de unde plătești</strong>. Implicit ai 3: Cash, Card, Tichete.</p>
        <p>Pentru 2 utilizatori, recomandare:</p>
        <ul>
          <li>Editează "Cash" → "Cash Andrei", proprietar: Andrei</li>
          <li>Adaugă "Cash Maria", proprietar: Maria</li>
          <li>Repetă pentru Card și Tichete</li>
        </ul>
        <p>Adaugă/editează în <em>Setări → 🏦 Conturi</em>.</p>
      </div>

      <div class="help-section">
        <h3>💰 Buget lunar</h3>
        <p>Bugetul este per <strong>lună</strong> și per <strong>cont</strong>. Mergi la <strong>Buget</strong>, schimbi luna cu săgețile ←/→, și pentru fiecare cont scrii suma și apeși Salvează.</p>
        <p>Pe Acasă, bara verde de progres îți arată cât din bugetul total ai folosit.</p>
      </div>

      <div class="help-section">
        <h3>🔄 Sincronizare</h3>
        <p>Toate datele se salvează automat în cloud după ~1.5 secunde de la modificare. Apasă <strong>↻ Sync</strong> în bara de sus pentru a forța preluarea datelor celuilalt utilizator.</p>
        <p><strong>Status:</strong> 🟢 = sincronizat, 🔄 = se sincronizează, 🔴 = eroare.</p>
        <div class="help-tip"><strong>💡 Tip:</strong> Apasă Sync înainte să modifici dacă celălalt a folosit recent aplicația — eviți suprascrierea.</div>
      </div>

      <div class="help-section">
        <h3>📲 Instalare pe telefon</h3>
        <p>Pentru a avea aplicația pe ecranul principal:</p>
        <ul>
          <li>Deschide aplicația în <strong>Chrome</strong> pe Android</li>
          <li>Meniu <strong>⋮</strong> → <strong>Add to Home Screen</strong></li>
          <li>Confirmă numele → Add</li>
        </ul>
        <p>Pe iPhone (Safari): <em>Share → Add to Home Screen</em>.</p>
      </div>

      <div class="help-section">
        <h3>🛠️ Probleme</h3>
        <p><strong>"Cod invalid sau cheie API greșită"</strong> — verifică că ambii utilizatori folosesc aceeași cheie API JSONBin.</p>
        <p><strong>"Eroare sincronizare"</strong> — apasă ↻ Sync. Dacă persistă, verifică conexiunea la internet.</p>
        <p><strong>Nu se actualizează modificările celuilalt</strong> — apasă manual ↻ Sync. Sincronizarea automată se întâmplă doar când modifici tu ceva.</p>
      </div>

      <div class="help-section">
        <h3>🔒 Confidențialitate</h3>
        <ul>
          <li>Datele sunt stocate pe JSONBin într-un fișier privat</li>
          <li>Doar persoanele cu cheia API + codul de partajare pot accesa datele</li>
          <li>Nu partaja cheia API public (ea îți permite să accesezi toate fișierele tale JSONBin)</li>
          <li>Pentru a șterge totul: deconectare (Resetează tot) + șterge bin-ul de pe jsonbin.io</li>
        </ul>
      </div>

      <div style="text-align:center;margin-top:24px;padding:20px;color:var(--text3);font-size:11px">
        <div style="font-size:24px;margin-bottom:8px">💳</div>
        Cheltuieli RON · v3 (JSONBin Cloud)
      </div>
    </div>`;
}

// ════════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════════
function changeMonth(dir) { selectedMonth=shiftMonth(selectedMonth,dir); renderView(); }
function openModal()  { document.getElementById('modal-overlay').classList.add('open'); }
function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }

let toastTmr;
function showToast(msg,type='') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast show ${type}`;
  clearTimeout(toastTmr);
  toastTmr = setTimeout(()=>{ t.className='toast'; }, 2800);
}
</script>
