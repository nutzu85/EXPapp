      <div style="font-size:10px;color:var(--text3);margin-right:6px">${(usage[cat.id]||0)>0?(usage[cat.id]||0)+' chelt.':''}</div>
      <button class="icon-btn" onclick="editCat('${cat.id}')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
      <button class="icon-btn del" onclick="delCat('${cat.id}',${usage[cat.id]||0})"><svg viewBox="0 0 24 24"><polyline points="3,6 5,6 21,6"/><path d="M19,6l-1,14H6L5,6"/><path d="M10,11v6M14,11v6"/><path d="M9,6V4h6v2"/></svg></button>
    </div>`).join('');

  let accItems = (appData.accounts||[]).map(acc=>`
    <div class="acc-item t-${acc.type}">
      <div class="acc-item-emoji">${acc.emoji}</div>
      <div class="acc-item-info">
        <div class="acc-item-name">${acc.name}</div>
        <div class="acc-item-meta">${acc.type==='cash'?'💵 Cash':acc.type==='card'?'💳 Card':'🎟️ Tichete'} · ${acc.owner?`👤 ${acc.owner}`:'Comun'} ${(accUsage[acc.id]||0)>0?`· ${accUsage[acc.id]} chelt.`:''}</div>
      </div>
      <button class="icon-btn" onclick="editAcc('${acc.id}')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
      <button class="icon-btn del" onclick="delAcc('${acc.id}',${accUsage[acc.id]||0})"><svg viewBox="0 0 24 24"><polyline points="3,6 5,6 21,6"/><path d="M19,6l-1,14H6L5,6"/><path d="M10,11v6M14,11v6"/><path d="M9,6V4h6v2"/></svg></button>
    </div>`).join('');

  c.innerHTML = `
    <div class="page-header"><div class="page-title">Setări</div><div class="page-subtitle">Cont și configurare</div></div>
    <div class="settings-view">

      <button class="btn-secondary" onclick="navigate('help')" style="margin-bottom:14px;display:flex;align-items:center;justify-content:center;gap:8px;border-color:rgba(0,214,143,0.3);color:var(--accent);background:var(--accent-dim)">
        <span style="font-size:16px">📖</span><span>Cum funcționează (ghid)</span>
      </button>

      <div class="section-title" style="margin-bottom:8px">👤 Cont</div>
      <div class="budget-card" style="margin-bottom:14px">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
          <div class="avatar" style="width:42px;height:42px;font-size:16px;border-radius:50%">${(userName||'?').slice(0,2).toUpperCase()}</div>
          <div><div style="font-weight:600;font-size:14px">${userName}</div><div style="font-size:12px;color:var(--text2)">utilizator</div></div>
        </div>
      </div>

      <div class="section-title" style="margin-bottom:8px;display:flex;justify-content:space-between;align-items:center">
        <span>🏦 Conturi (${(appData.accounts||[]).length})</span>
        <button class="link-btn" onclick="showAddAccountModal()" style="font-size:12px;text-transform:none;letter-spacing:normal">+ Adaugă cont</button>
      </div>
      <div style="margin-bottom:8px">${accItems}</div>
      <div style="font-size:11px;color:var(--text3);margin:4px 0 14px;line-height:1.5">💡 Adaugă conturi separate pentru fiecare utilizator (ex: "Cash Andrei", "Card Maria").</div>

      <div class="section-title" style="margin-bottom:8px">☁️ Sincronizare cloud</div>
      <div class="budget-card" style="margin-bottom:14px">
        <div class="info-row" style="border-top:none"><span class="info-label">Cod partajare</span><span class="info-value" style="max-width:160px;overflow:hidden;text-overflow:ellipsis">${shareCode}</span></div>
        <div class="info-row"><span class="info-label">Ultima sincronizare</span><span class="info-value">${lastSyncAt?formatTime(lastSyncAt):'—'}</span></div>
        <div class="info-row"><span class="info-label">Modificat de</span><span class="info-value">${lastSyncBy||'—'}</span></div>
        <div class="info-row"><span class="info-label">Cheltuieli totale</span><span class="info-value">${appData.expenses.length}</span></div>
        <div style="height:10px"></div>
        <button class="btn-secondary" onclick="showShareCodeModal()" style="margin-bottom:8px">📤 Arată codul (partajare)</button>
        <button class="btn-secondary" onclick="manualSync()">↻ Sincronizează acum</button>
      </div>

      <div class="section-title" style="margin-bottom:8px">🏷️ Categorii</div>
      <div class="cat-add-form">
        <input type="text" class="emoji-inp" id="new-emoji" placeholder="😊" maxlength="2">
        <input type="text" class="name-inp" id="new-name" placeholder="Nume categorie">
        <button class="cat-add-btn" onclick="addCat()">+ Adaugă</button>
      </div>
      ${catItems}

      <div style="height:8px"></div>
      <div class="section-title" style="margin-bottom:8px">⚠️ Date</div>
      <button class="btn-secondary btn-danger" onclick="confirmReset()" style="margin-bottom:8px">Șterge cheltuieli luna curentă</button>
      <button class="btn-secondary btn-danger" onclick="resetAll()">Resetează tot (deconectare)</button>
    </div>`;

  document.getElementById('new-name').addEventListener('keydown',e=>{ if(e.key==='Enter') addCat(); });
}

// ── Account management ──
function showAddAccountModal(editingAcc) {
  const isEdit = !!editingAcc;
  const acc = editingAcc || { name:'', type:'cash', emoji:'💵', owner:'' };
  // Get all known names from existing data
  const knownNames = [...new Set([userName, ...((appData.expenses||[]).map(e=>e.addedBy).filter(Boolean))])];
  const ownerOpts = knownNames.map(n => `<option value="${n}" ${acc.owner===n?'selected':''}>👤 ${n}</option>`).join('');

  document.getElementById('modal-content').innerHTML = `
    <div class="modal-title">${isEdit?'Editează cont':'Cont nou'}</div>
    <div class="form-group" style="margin-bottom:14px">
      <label class="form-label-sm">Nume cont</label>
      <input type="text" class="form-inp" id="new-acc-name" placeholder="Ex: Cash Andrei, Card BCR..." value="${acc.name}">
    </div>
    <div class="form-group" style="margin-bottom:14px">
      <label class="form-label-sm">Tip</label>
      <div class="toggle-group">
        <button class="tog-btn ${acc.type==='cash'?'cash-on':''}" id="acc-type-cash" onclick="setAccType('cash')"><span class="tog-emoji">💵</span><span>Cash</span></button>
        <button class="tog-btn ${acc.type==='card'?'card-on':''}" id="acc-type-card" onclick="setAccType('card')"><span class="tog-emoji">💳</span><span>Card</span></button>
        <button class="tog-btn ${acc.type==='tichete'?'tichete-on':''}" id="acc-type-tichete" onclick="setAccType('tichete')"><span class="tog-emoji">🎟️</span><span>Tichete</span></button>
      </div>
    </div>
    <div class="form-group" style="margin-bottom:14px">
      <label class="form-label-sm">Emoji</label>
      <input type="text" class="form-inp" id="new-acc-emoji" maxlength="2" value="${acc.emoji}" style="text-align:center;font-size:24px">
    </div>
    <div class="form-group" style="margin-bottom:18px">
      <label class="form-label-sm">Proprietar (opțional)</label>
      <select class="form-inp" id="new-acc-owner">
        <option value="" ${!acc.owner?'selected':''}>Cont comun (fără proprietar)</option>
        ${ownerOpts}
      </select>
    </div>
    ${isEdit?`<button class="btn-primary" onclick="saveEditAcc('${acc.id}')">Salvează</button>`:`<button class="btn-primary" onclick="saveNewAcc()">+ Adaugă cont</button>`}`;
  pendingAccType = acc.type;
  openModal();
}

function setAccType(t) {
  pendingAccType = t;
  document.querySelectorAll('#modal-content .tog-btn').forEach(b=>b.classList.remove('cash-on','card-on','tichete-on'));
  document.getElementById('acc-type-'+t).classList.add(t+'-on');
  const emojiInp = document.getElementById('new-acc-emoji');
  const defaults = { cash:'💵', card:'💳', tichete:'🎟️' };
  if (Object.values(defaults).includes(emojiInp.value)) emojiInp.value = defaults[t];
}

function saveNewAcc() {
  const name  = document.getElementById('new-acc-name').value.trim();
  const emoji = document.getElementById('new-acc-emoji').value.trim()||'💵';
  const owner = document.getElementById('new-acc-owner').value;
  if (!name) { showToast('Adaugă un nume!','err'); return; }
  appData.accounts.push({ id: genId(), name, type: pendingAccType, emoji, owner });
  scheduleSave();
  closeModal();
  showToast('Cont adăugat ✓','ok');
  renderSettings();
}

function editAcc(id) {
  const acc = appData.accounts.find(a=>a.id===id);
  if (acc) showAddAccountModal(acc);
}

function saveEditAcc(id) {
  const name  = document.getElementById('new-acc-name').value.trim();
  const emoji = document.getElementById('new-acc-emoji').value.trim()||'💵';
  const owner = document.getElementById('new-acc-owner').value;
  if (!name) { showToast('Adaugă un nume!','err'); return; }
  const acc = appData.accounts.find(a=>a.id===id);
  if (acc) { acc.name=name; acc.emoji=emoji; acc.owner=owner; acc.type=pendingAccType; }
  scheduleSave();
  closeModal();
  showToast('Cont actualizat ✓','ok');
  renderSettings();
}

function delAcc(id, count) {
  const acc = appData.accounts.find(a=>a.id===id);
  if (!acc) return;
  if (count>0 && !confirm(`Contul "${acc.name}" are ${count} cheltuieli. Continui?`)) return;
  if (count===0 && !confirm(`Ștergi contul "${acc.name}"?`)) return;
  appData.accounts = appData.accounts.filter(a=>a.id!==id);
  Object.values(appData.budgets||{}).forEach(b=>{ delete b[id]; });
  scheduleSave();
  showToast('Cont șters','ok');
  renderSettings();
}

function addCat() {
  const emoji = document.getElementById('new-emoji').value.trim()||'📦';
  const name  = document.getElementById('new-name').value.trim();
  if (!name) { showToast('Adaugă un nume!','err'); return; }
  appData.categories.push({ id: genId(), name, emoji });
  scheduleSave();
  showToast('Adăugat ✓','ok');
  renderSettings();
}

function delCat(id,count) {
  const cat = getCat(id);
  if (!confirm(`Ștergi "${cat.name}"${count>0?` (${count} cheltuieli)`:''}?`)) return;
  appData.categories = appData.categories.filter(c=>c.id!==id);
  scheduleSave();
  showToast('Șters','ok');
  renderSettings();
}

function editCat(id) {
  const cat = getCat(id);
  document.getElementById('modal-content').innerHTML = `
    <div class="modal-title">Editează</div>
    <div class="form-group" style="margin-bottom:14px"><label class="form-label-sm">Emoji</label><input type="text" class="form-inp" id="e-emoji" value="${cat.emoji}" maxlength="2" style="text-align:center;font-size:30px"></div>
    <div class="form-group" style="margin-bottom:16px"><label class="form-label-sm">Nume</label><input type="text" class="form-inp" id="e-name" value="${cat.name}"></div>
    <button class="btn-primary" onclick="saveEditCat('${id}')">Salvează</button>`;
  openModal();
}

function saveEditCat(id) {
  const emoji = document.getElementById('e-emoji').value.trim()||'📦';
  const name  = document.getElementById('e-name').value.trim();
  if (!name) { showToast('Adaugă un nume!','err'); return; }
  const cat = appData.categories.find(c=>c.id===id);
  if (cat) { cat.emoji=emoji; cat.name=name; }
  scheduleSave();
  closeModal();
  showToast('Actualizat ✓','ok');
  renderSettings();
}

function confirmReset() {
  if (!confirm(`Ștergi toate cheltuielile din ${formatMonth(selectedMonth)}?`)) return;
  appData.expenses = appData.expenses.filter(e=>monthKey(e.date)!==selectedMonth);
  scheduleSave();
  showToast('Șterse ✓','ok');
  renderSettings();
}

// ════════════════════════════════════════════════════════════════
//  EXPENSE HTML
// ════════════════════════════════════════════════════════════════
function expHtml(exp) {
  const cat = getCat(exp.categoryId);
  const acc = getAccount(exp.accountId||('acc-'+(exp.method||'cash')));
  const type = acc.type||'cash';
  const isMine = exp.addedBy === userName || !exp.addedBy;
  const itemCls = type==='cash'?'cash-item':type==='card'?'card-item':'tichete-item';
  const iconBg  = type==='cash'?'var(--accent-dim)':type==='card'?'var(--card-dim)':'var(--tichete-dim)';
  const badgeCls = type==='cash'?'badge-cash':type==='card'?'badge-card':'badge-tichete';
  const author = exp.addedBy||userName;
  const initials = author.slice(0,2).toUpperCase();
  const accLabel = `${acc.emoji} ${acc.name}${acc.owner?` (${acc.owner})`:''}`;

  return `
    <div class="expense-item ${itemCls}">
      <div class="exp-icon" style="background:${iconBg}">${cat.emoji}</div>
      <div class="exp-info">
        <div class="exp-desc">${exp.description}</div>
        <div class="exp-meta">
          <span class="exp-badge ${badgeCls}">${accLabel}</span>
          ${cat.name} · ${formatDate(exp.date)}
          <span class="added-by"><span class="ab-avatar ${isMine?'ab-me':'ab-other'}">${initials}</span>${author}</span>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px">
        <div class="exp-amount">-${formatRon(exp.amount)}</div>
        <div class="exp-actions">
          <button class="icon-btn" onclick="startEdit('${exp.id}')"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
          <button class="icon-btn del" onclick="deleteExpense('${exp.id}')"><svg viewBox="0 0 24 24"><polyline points="3,6 5,6 21,6"/><path d="M19,6l-1,14H6L5,6"/><path d="M10,11v6M14,11v6"/><path d="M9,6V4h6v2"/></svg></button>
        </div>
      </div>
    </div>`;
}

function startEdit(id) {
  const exp = appData.expenses.find(e=>e.id===id);
  if (!exp) return;
  currentView = 'add';
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('nav-add').classList.add('active');
  renderAdd(exp);
}

function deleteExpense(id) {
  if (!confirm('Ștergi această cheltuială?')) return;
  appData.expenses = appData.expenses.filter(e=>e.id!==id);
  scheduleSave();
  showToast('Șters','ok');
  renderView();
}

